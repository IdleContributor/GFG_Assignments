{
  "rewrites": [
    { "source": "/", "destination": "/Master/index.html" },
    { "source": "/a1", "destination": "/A1/index.html" },
    { "source": "/a2", "destination": "/A2/index.html" },
    { "source": "/a3", "destination": "/A3/index.html" },
    { "source": "/a4", "destination": "/A4/index.html" },
    { "source": "/a5", "destination": "/A5/dist/index.html" },
    { "source": "/a6", "destination": "/A6/dist/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
